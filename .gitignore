# ══════════════════════════════════════════════════════════════════════════════
# EyeGuide — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg

# ─── Virtual Environment ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Environment Variables ───────────────────────────────────────────────────
.env
.env.local
.env.production

# ─── IDE / Editor ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Google Cloud ────────────────────────────────────────────────────────────
*.json
!package.json
!cloudbuild.yaml
service-account-key.json
gcloud-credentials.json

# ─── Docker ──────────────────────────────────────────────────────────────────
backend/static/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Node (if any) ──────────────────────────────────────────────────────────
node_modules/

# ─── OS Files ────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
desktop.ini
