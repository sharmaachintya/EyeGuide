# ──────────────────────────────────────────────────────────────────────────────
# EyeGuide Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Google Cloud Configuration ──────────────────────────────────────────────
# Your Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=your-project-id

# Region for Vertex AI (us-central1 recommended)
GOOGLE_CLOUD_LOCATION=us-central1

# Set to TRUE to use Vertex AI (required for Cloud Run deployment)
# Set to FALSE to use Google AI Studio (for local development)
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# ─── API Keys (only needed if GOOGLE_GENAI_USE_VERTEXAI=FALSE) ──────────────
# Get your API key from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-api-key-here

# ─── Model Configuration ────────────────────────────────────────────────────
# Gemini Live API model to use
GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001

# ─── Server Configuration ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
ALLOWED_ORIGINS=*

# ─── Application Configuration ──────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
